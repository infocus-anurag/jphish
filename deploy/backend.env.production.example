# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION backend env  ->  copy to  backend/.env  ON THE SERVER  (never commit)
# Fill every <PLACEHOLDER>. Generate secrets with:  openssl rand -base64 48
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001
HOST=127.0.0.1          # bind admin API to localhost; nginx proxies to it

# ── PostgreSQL (installed locally via apt, listening on 127.0.0.1) ──
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=jphish
DB_PASSWORD=<STRONG_DB_PASSWORD>
DB_NAME=jphish

# ── Redis (installed locally via apt, requirepass set) ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=<STRONG_REDIS_PASSWORD>
REDIS_DB=0

# ── JWT — two DISTINCT secrets, >= 32 random bytes each ──
JWT_ACCESS_SECRET=<RANDOM_48_BYTES_A>
JWT_REFRESH_SECRET=<RANDOM_48_BYTES_B>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# ── Account lockout ──
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# ── Refresh cookie ──
# Host-only on the admin domain. Do NOT use ".infocusit.in" (leading dot) —
# that would leak the admin cookie to the phish subdomain, defeating the
# separate-origin design.
COOKIE_DOMAIN=jphish.infocusit.in
COOKIE_SECURE=true

# ── First-run super-admin (seeded only when the users table is empty) ──
# You will be forced to change this password on first login.
BOOTSTRAP_SUPERADMIN_EMAIL=admin@infocusit.in
BOOTSTRAP_SUPERADMIN_PASSWORD=<STRONG_TEMP_PASSWORD>

# ── Outbound email (real SMTP). Gmail needs a 16-char App Password. ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=<your-smtp-user>
MAIL_PASSWORD=<your-smtp-app-password>
MAIL_FROM="PhishGuard <noreply@infocusit.in>"
MAIL_DEV_MODE=                       # empty = real SMTP (use 'file' or 'ethereal' to test)

# ── API origin / CORS (exact admin origin, no trailing slash) ──
API_URL=https://jphish.infocusit.in
API_CORS_ORIGIN=https://jphish.infocusit.in

# ── Public phish-server (separate origin) ──
PHISH_PORT=3002
PHISH_HOST=127.0.0.1
PUBLIC_LANDING_URL=https://links.infocusit.in   # baked into outbound emails

# ── Bull dashboard ──
BULL_DASHBOARD_URL=/bull
BULL_DASHBOARD_PASSWORD=<STRONG_BULL_PASSWORD>

# ── FIRST BOOT ONLY ──
# Creates the full schema from the entities (the committed migration is
# incomplete). Set to true for the very first start, confirm the tables exist,
# then change to false (or delete this line) and restart. Leaving it on in
# steady state risks unintended schema changes.
DB_SYNCHRONIZE=true
