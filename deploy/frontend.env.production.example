# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION frontend env  ->  copy to  frontend/.env.production  ON THE SERVER
# IMPORTANT: every NEXT_PUBLIC_* value is BAKED IN at `npm run build` time.
# If you change any of these, you must REBUILD the frontend.
# ─────────────────────────────────────────────────────────────────────────────

# Admin API as reached from the BROWSER. Note the /api/v1 suffix
# (global prefix "api" + URI version "1").
NEXT_PUBLIC_API_URL=https://jphish.infocusit.in/api/v1
NEXT_PUBLIC_APP_URL=https://jphish.infocusit.in

# Public phish surface origin (separate subdomain).
NEXT_PUBLIC_PHISH_URL=https://links.infocusit.in

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_DEBUG=false

# Auth
NEXT_PUBLIC_AUTH_DOMAIN=jphish.infocusit.in
NEXT_PUBLIC_JWT_EXPIRY=15m
