# Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=phishguard
DB_PASSWORD=changeme123
DB_NAME=phishguard_db

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
